#MCP_TAP_UPSTREAM_PROVIDER="openrouter"
MCP_TAP_UPSTREAM_PROVIDER="requesty"

MCP_TAP_LISTEN_HOST=127.0.0.1
MCP_TAP_LISTEN_PORT=8787

# Optional. Leave empty to let OpenRouter choose an endpoint for the forced model.
# To pin one endpoint provider, put its OpenRouter provider slug here.
MCP_TAP_OPENROUTER_PROVIDER=

# With :floor, this prevents trying another endpoint when the cheapest one fails.
MCP_TAP_OPENROUTER_DISABLE_PROVIDER_FALLBACKS=0

MCP_TAP_PLAN_MODE_MAX_INPUT_SIZE=300000

MCP_TAP_LOG_LEVEL=INFO
#MCP_TAP_LOG_LEVEL=DEBUG
#MCP_TAP_LOG_FILE=/tmp/mcptap.log

#MCP_TAP_INTERCEPT_YAML=@/home/user/.config/mcptap/mcp-intercept.yaml
MCP_TAP_INTERCEPT_YAML=
MCP_TAP_INTERCEPT_TOOL_TIMEOUT=300
MCP_TAP_INTERCEPT_MAX_ITERATIONS=8

#MCP_TAP_PER_MODEL_YAML=@/home/user/.config/mcptap/per-model.yaml
MCP_TAP_PER_MODEL_YAML=

# Optional tool-call hook. When set, MCPTap runs this script before
# each batch of client tool calls to decide whether to allow or block them.
#MCP_TAP_USE_TOOL_HOOK=/home/user/.config/mcptap/use_tool_hook.py
MCP_TAP_USE_TOOL_HOOK=
MCP_TAP_USE_TOOL_HOOK_TIMEOUT=30

# When set, the proxy injects a synthetic call to this tool name before
# running the hook (e.g. get_goal). When empty, the hook runs immediately
# without injecting any synthetic tool call.
#MCP_TAP_USE_TOOL_HOOK_SYNTHETIC_TOOL=get_goal
MCP_TAP_USE_TOOL_HOOK_SYNTHETIC_TOOL=get_goal

# Path to the LD_PRELOAD shared library for file access blocking.
# Build it from mcp-tap/file_block/ with: make && make install
#MCP_TAP_FILE_BLOCK_LIB=/home/user/.local/lib/libmcptap_fileblock.so
MCP_TAP_FILE_BLOCK_LIB=

# Directory for per-session blocklist control files.
MCP_TAP_BLOCKLIST_DIR=/tmp/mcptap_blocklists

# Optional environment variables for MCP tools launched by mcp-intercept.yaml.
LLM_COUNCIL_API_TOKEN="41a.....b20"
LLM_COUNCIL_CONFIG="/home/user/.config/llm-council/llm_council.yaml"
LLM_COUNCIL_OPENROUTER_API_KEY="sk-or-v1-df1.....24e"
LLM_COUNCIL_REQUESTY_API_KEY="rqsty-sk-ki1.....2QY="
