#MCP_TAP_UPSTREAM_PROVIDER="openrouter"
MCP_TAP_UPSTREAM_PROVIDER="requesty"

MCP_TAP_LISTEN_HOST=127.0.0.1
MCP_TAP_LISTEN_PORT=8787

# Optional. Leave empty to let OpenRouter choose an endpoint for the forced model.
# To pin one endpoint provider, put its OpenRouter provider slug here.
MCP_TAP_OPENROUTER_PROVIDER=

# With :floor, this prevents trying another endpoint when the cheapest one fails.
MCP_TAP_OPENROUTER_DISABLE_PROVIDER_FALLBACKS=0

MCP_TAP_PLAN_MODE_MAX_INPUT_SIZE=100000

MCP_TAP_LOG_LEVEL=INFO
#MCP_TAP_LOG_LEVEL=DEBUG
MCP_TAP_LOG_FILE=/tmp/mcptap.log

#MCP_TAP_INTERCEPT_JSON=@/home/user/.config/mcptap/mcp-intercept.json
MCP_TAP_INTERCEPT_JSON=

MCP_TAP_INTERCEPT_TOOL_TIMEOUT=300
MCP_TAP_INTERCEPT_MAX_ITERATIONS=8

# Optional environment variables for MCP tools launched by mcp-intercept.json.
#LLM_COUNCIL_API_TOKEN="41a.....b20"
#LLM_COUNCIL_CONFIG="/home/user/.config/llm-council/llm_council.yaml"
#LLM_COUNCIL_OPENROUTER_API_KEY="sk-or-v1-df1.....24e"
#LLM_COUNCIL_REQUESTY_API_KEY="rqsty-sk-ki1.....2QY="
